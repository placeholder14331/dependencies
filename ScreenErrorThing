local ignored = {}

local function showLog(msg, color)
    local baseMsg = tostring(msg):match("^[^\n]+") or tostring(msg) -- só 1a linha como chave
    if ignored[baseMsg] then return end

    order = order + 1
    local myOrder = order

    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(1, 0, 0, 0)
    bg.AutomaticSize = Enum.AutomaticSize.Y
    bg.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
    bg.BackgroundTransparency = 0.3
    bg.LayoutOrder = myOrder
    bg.Parent = Frame
    Instance.new("UICorner", bg).CornerRadius = UDim.new(0, 5)

    local pad = Instance.new("UIPadding", bg)
    pad.PaddingLeft = UDim.new(0, 8)
    pad.PaddingRight = UDim.new(0, 8)
    pad.PaddingTop = UDim.new(0, 4)
    pad.PaddingBottom = UDim.new(0, 4)

    local label = Instance.new("TextLabel", bg)
    label.Size = UDim2.new(1, -60, 0, 0)
    label.AutomaticSize = Enum.AutomaticSize.Y
    label.BackgroundTransparency = 1
    label.TextColor3 = color
    label.TextSize = 12
    label.Font = Enum.Font.Code
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextWrapped = true
    label.Text = tostring(msg)

    local ignoreBtn = Instance.new("TextButton", bg)
    ignoreBtn.Size = UDim2.new(0, 52, 0, 18)
    ignoreBtn.Position = UDim2.new(1, -52, 0, 0)
    ignoreBtn.BackgroundColor3 = Color3.fromRGB(60, 20, 20)
    ignoreBtn.BorderSizePixel = 0
    ignoreBtn.Text = "ignorar"
    ignoreBtn.TextColor3 = Color3.fromRGB(255, 120, 120)
    ignoreBtn.TextSize = 11
    ignoreBtn.Font = Enum.Font.Code
    Instance.new("UICorner", ignoreBtn).CornerRadius = UDim.new(0, 4)

    ignoreBtn.MouseButton1Click:Connect(function()
        ignored[baseMsg] = true
        for _, child in ipairs(Frame:GetChildren()) do
            if child:IsA("Frame") then
                local lbl = child:FindFirstChildOfClass("TextLabel")
                if lbl and (lbl.Text:match("^[^\n]+") or lbl.Text) == ("✖ " .. baseMsg) then
                    child:Destroy()
                end
            end
        end
    end)

    task.delay(3, function()
        if bg and bg.Parent then bg:Destroy() end
    end)
end
